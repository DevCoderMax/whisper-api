# Modelo — opções: tiny, small, medium, large-v2, large-v3
WHISPER_MODEL=small

# Dispositivo — "cuda" para GPU, "cpu" para processador
WHISPER_DEVICE=cuda

# Tipo de computação — "float16" (GPU), "int8" (CPU)
WHISPER_COMPUTE_TYPE=float16

# Threads de CPU (só importa se WHISPER_DEVICE=cpu)
WHISPER_CPU_THREADS=4

# Idioma padrão das transcrições
DEFAULT_LANGUAGE=pt

# Tamanho máximo do upload em MB
MAX_UPLOAD_SIZE_MB=500

# Filtro VAD (remove silêncios automaticamente)
VAD_FILTER=true
